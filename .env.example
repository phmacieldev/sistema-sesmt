# .env.example — copie para .env e preencha os valores reais
# Equivalente ao .env do projeto Flask

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pgeo_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
SECRET_KEY=troque-por-uma-chave-secreta-longa

# Senhas dos usuários padrão criados no primeiro boot (opcional — sem elas,
# valores de desenvolvimento são usados como fallback). Defina sempre em produção.
ADMIN_PASSWORD=troque-esta-senha
OPERADOR_PASSWORD=troque-esta-senha
VISUALIZADOR_PASSWORD=troque-esta-senha
